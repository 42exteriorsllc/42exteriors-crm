# React app (frontend) — stored in .env.local
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Function secrets — set via:
#   supabase secrets set KEY=value
#
# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_PHONE=+1xxxxxxxxxx   # Twilio phone number

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=notifications@yourdomain.com   # must be a verified domain in Resend

# Business owner contact
OWNER_PHONE=+1xxxxxxxxxx
OWNER_EMAIL=owner@yourdomain.com
